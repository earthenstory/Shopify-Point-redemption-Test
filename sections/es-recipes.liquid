{%- comment -%}
  sections/product-recipes.liquid
  Earthen Story — Recipes grid. Works on product, collection, article templates.

  Auto-detects the current object and reads the correct metafield:
    product    → custom.product_related_recipes   (semicolon-separated handles)
    collection → custom.related_recipes           (semicolon-separated handles)
    article    → custom.recipe_related_recipes    (semicolon-separated handles)

  Blog handle (where articles live) is set via section settings so it can
  be overridden per-template without changing this file.
{%- endcomment -%}

{%- liquid
  assign blog_handle = section.settings.blog_handle | default: 'recipes'

  if product != blank
    assign raw_value = product.metafields.custom.product_related_recipes.value
    if raw_value == blank
      assign raw_value = product.metafields.custom.bundle_related_recipes.value
    endif
  elsif collection != blank
    assign raw_value = collection.metafields.custom.related_recipes.value
  elsif article != blank
    assign raw_value = article.metafields.custom.recipe_related_recipes.value
    if raw_value == blank
      assign raw_value = article.metafields.custom.blog_related_recipes.value
    endif
  endif

  assign recipe_handles = raw_value | split: ';'
-%}

{%- if raw_value != blank -%}

<div class="esd-section-inner">
  <div class="esd-section-header">
    <h2 class="esd-section-title">{{ section.settings.title | default: 'Recipes' }}</h2>
    {%- if section.settings.show_view_all -%}
      <a href="/blogs/{{ blog_handle }}" class="esd-view-all-link">All Recipes →</a>
    {%- endif -%}
  </div>

  <div class="esd-article-grid">
    {%- assign count = 0 -%}
    {%- for handle_raw in recipe_handles -%}
      {%- if count >= 3 -%}{%- break -%}{%- endif -%}
      {%- assign a_handle = handle_raw | strip -%}
      {%- assign full_path = blog_handle | append: '/' | append: a_handle -%}
      {%- assign found = articles[full_path] -%}
      {%- if found != blank -%}
        {%- assign count = count | plus: 1 -%}
        {%- assign time_tag = found.metafields.custom.recipe_time_tag.value -%}
        <a href="{{ found.url }}" class="esd-card">
          <div class="esd-recipe-img">
            {%- if found.image -%}
              {{ found.image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  alt: found.image.alt | default: found.title,
                  width: 600, height: 400,
                  widths: '300, 450, 600',
                  sizes: '(min-width: 990px) 25vw, 50vw',
                  style: 'object-fit:cover'
              }}
            {%- endif -%}
          </div>
          <div class="esd-card-body">
            <div class="esd-card-tag">{%- if time_tag != blank -%}{{ time_tag }}{%- else -%}Recipe{%- endif -%}</div>
            <h3 class="esd-card-title">{{ found.title }}</h3>
            {%- if found.excerpt != blank -%}
              <div class="esd-card-meta">{{ found.excerpt | strip_html | truncate: 80 }}</div>
            {%- endif -%}
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{%- endif -%}

{% schema %}
{
  "name": "Recipes",
  "tag": "section",
  "class": "product-recipes-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section heading",
      "default": "Recipes"
    },
    {
      "type": "text",
      "id": "blog_handle",
      "label": "Blog handle",
      "default": "recipes",
      "info": "Handle of the Shopify blog where recipe articles live. Found in Online Store → Blogs."
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'All Recipes' link",
      "default": true
    }
  ],
  "presets": [{ "name": "Recipes" }]
}
{% endschema %}
