{{ 'our-story.css' | asset_url | stylesheet_tag }}

<!-- ══════════════════════════════════════
     1. OPENING
══════════════════════════════════════ -->
<section class="opening">
  <div class="opening-inner">
    <div class="opening-quote">"{{ section.settings.opening_quote | remove: '<p>' | remove: '</p>' }}"</div>
    <p class="opening-body">{{ section.settings.opening_body }}</p>
  </div>
</section>

<!-- ══════════════════════════════════════
     2. TWO PROBLEMS
══════════════════════════════════════ -->
{%- assign problem_cards = section.blocks | where: "type", "problem_card" -%}
{%- if problem_cards.size > 0 -%}
<section class="page-section alt">
  <div class="section-inner">
    <h2 class="section-heading">{{ section.settings.problems_heading }}</h2>
    <div class="problems-grid">

      {%- for block in problem_cards -%}
        {%- assign problem_num = forloop.index -%}
        {%- assign solution_anchor = '#solution-' | append: problem_num -%}
        {%- comment -%} Accepts youtu.be/, youtube.com/shorts/, /embed/, and watch?v= URLs (or a bare ID). {%- endcomment -%}
        {%- assign _raw_prob_yt = block.settings.video_id -%}
        {%- if _raw_prob_yt contains 'youtu.be/' -%}
          {%- assign _prob_vid = _raw_prob_yt | split: 'youtu.be/' | last | split: '?' | first | split: '/' | first -%}
        {%- elsif _raw_prob_yt contains '/shorts/' -%}
          {%- assign _prob_vid = _raw_prob_yt | split: '/shorts/' | last | split: '?' | first | split: '/' | first -%}
        {%- elsif _raw_prob_yt contains '/embed/' -%}
          {%- assign _prob_vid = _raw_prob_yt | split: '/embed/' | last | split: '?' | first | split: '/' | first -%}
        {%- elsif _raw_prob_yt contains 'v=' -%}
          {%- assign _prob_vid = _raw_prob_yt | split: 'v=' | last | split: '&' | first -%}
        {%- else -%}
          {%- assign _prob_vid = _raw_prob_yt -%}
        {%- endif -%}
        <div class="problem-card" {{ block.shopify_attributes }}>
          <div class="problem-header">
            <span class="problem-num">Problem 0{{ problem_num }}</span>
            <span class="problem-icon">{{ block.settings.icon }}</span>
            <div class="problem-title">{{ block.settings.title }}</div>
          </div>
          <div class="problem-body">{{ block.settings.body }}</div>
          {%- if _prob_vid != blank -%}
            <div class="problem-yt problem-yt--video">
              <iframe
                src="https://www.youtube.com/embed/{{ _prob_vid }}?rel=0&modestbranding=1"
                title="{{ block.settings.video_label }}"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy">
              </iframe>
            </div>
          {%- endif -%}
          <a href="{{ solution_anchor }}" class="problem-jump">How we address this ↓</a>
        </div>
      {%- endfor -%}

    </div>
  </div>
</section>
{%- endif -%}

<!-- ══════════════════════════════════════
     3. WHO WE ARE — FOUNDERS
══════════════════════════════════════ -->
<section class="page-section">
  <div class="section-inner">
    <h2 class="section-heading">{{ section.settings.founders_heading }}</h2>
    <div class="founders-grid">

      {% for block in section.blocks %}
        {% if block.type == 'founder' %}
          {%- comment -%} Accepts youtu.be/, youtube.com/shorts/, /embed/, and watch?v= URLs (or a bare ID). {%- endcomment -%}
          {%- assign _raw_yt = block.settings.youtube_video_id -%}
          {%- if _raw_yt contains 'youtu.be/' -%}
            {%- assign _founder_vid = _raw_yt | split: 'youtu.be/' | last | split: '?' | first | split: '/' | first -%}
          {%- elsif _raw_yt contains '/shorts/' -%}
            {%- assign _founder_vid = _raw_yt | split: '/shorts/' | last | split: '?' | first | split: '/' | first -%}
          {%- elsif _raw_yt contains '/embed/' -%}
            {%- assign _founder_vid = _raw_yt | split: '/embed/' | last | split: '?' | first | split: '/' | first -%}
          {%- elsif _raw_yt contains 'v=' -%}
            {%- assign _founder_vid = _raw_yt | split: 'v=' | last | split: '&' | first -%}
          {%- else -%}
            {%- assign _founder_vid = _raw_yt -%}
          {%- endif -%}
          <div class="founder-card" {{ block.shopify_attributes }}>
            {% if _founder_vid != blank %}
              <div class="founder-thumb-wrap has-video">
                <iframe
                  src="https://www.youtube.com/embed/{{ _founder_vid }}?rel=0&modestbranding=1"
                  title="{{ block.settings.name }} intro video"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy">
                </iframe>
              </div>
            {% else %}
              <div class="founder-thumb-wrap" style="cursor:default;">
                <div class="founder-thumb-inner">
                  {% if block.settings.photo != blank %}
                    {{ block.settings.photo | image_url: width: 600 | image_tag:
                        loading: 'lazy',
                        alt: block.settings.name,
                        widths: '300, 450, 600',
                        sizes: '(min-width: 990px) 20vw, 33vw',
                        style: 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:top center'
                    }}
                  {% endif %}
                </div>
                <div class="ft-name-bar">{{ block.settings.name }}</div>
              </div>
            {% endif %}
            <div class="founder-info">
              <div class="founder-name">{{ block.settings.name }}</div>
              <div class="founder-role">{{ block.settings.role }}</div>
              <div class="founder-creds">
                {% if block.settings.cred1 != blank %}
                  <div class="cred-item"><div class="cred-dot"></div>{{ block.settings.cred1 }}</div>
                {% endif %}
                {% if block.settings.cred2 != blank %}
                  <div class="cred-item"><div class="cred-dot"></div>{{ block.settings.cred2 }}</div>
                {% endif %}
              </div>
              <div class="founder-bio">{{ block.settings.bio }}</div>
              <div class="founder-links">
                {% if block.settings.linkedin_url != blank %}
                  <a href="{{ block.settings.linkedin_url }}" class="founder-link" target="_blank" rel="noopener">LinkedIn</a>
                {% endif %}
                {% if block.settings.youtube_url != blank %}
                  <a href="{{ block.settings.youtube_url }}" class="founder-link" target="_blank" rel="noopener">YouTube</a>
                {% endif %}
                {% if block.settings.substack_url != blank %}
                  <a href="{{ block.settings.substack_url }}" class="founder-link" target="_blank" rel="noopener">Substack</a>
                {% endif %}
                {% if block.settings.instagram_url != blank %}
                  <a href="{{ block.settings.instagram_url }}" class="founder-link" target="_blank" rel="noopener">Instagram</a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     4. SOLUTION 1 — Pesticides
══════════════════════════════════════ -->
<section class="page-section alt" id="solution-1">
  <div class="section-inner">
    <div class="section-label">Addressing Problem 01</div>
    <div class="solution-heading">{{ section.settings.solution1_heading }}</div>
    <div class="solution-grid">
      <div class="solution-card">
        <div class="sc-icon">{{ section.settings.sol1_card1_icon }}</div>
        <div class="sc-title">{{ section.settings.sol1_card1_title }}</div>
        <div class="sc-body">{{ section.settings.sol1_card1_body }}</div>
      </div>
      <div class="solution-card">
        <div class="sc-icon">{{ section.settings.sol1_card2_icon }}</div>
        <div class="sc-title">{{ section.settings.sol1_card2_title }}</div>
        <div class="sc-body">{{ section.settings.sol1_card2_body }}</div>
        <a href="{{ section.settings.lab_reports_url }}" class="btn-reports">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="12" y1="18" x2="12" y2="12"/>
            <line x1="9" y1="15" x2="15" y2="15"/>
          </svg>
          View All Lab Reports
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     5. SOLUTION 2 — Processing
══════════════════════════════════════ -->
<section class="page-section" id="solution-2">
  <div class="section-inner">
    <div class="section-label">Addressing Problem 02</div>
    <div class="solution-heading">{{ section.settings.solution2_heading }}</div>
    <div class="methods-strip">

      {% for block in section.blocks %}
        {% if block.type == 'method' %}
          <div class="method-row" {{ block.shopify_attributes }}>
            <div class="method-icon-sq">{{ block.settings.icon }}</div>
            <div class="method-text">
              <div class="method-tag">{{ block.settings.tag }}</div>
              <div class="method-name">{{ block.settings.name }}</div>
              <div class="method-desc">{{ block.settings.description }}</div>
            </div>
          </div>
        {% endif %}
      {% endfor %}

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     6. FOLLOW OUR THINKING
══════════════════════════════════════ -->
<section class="page-section alt">
  <div class="section-inner">
    <h2 class="section-heading">{{ section.settings.platforms_heading }}</h2>
    <p class="platforms-desc">{{ section.settings.platforms_desc }}</p>
    <div class="platforms-list">

      {%- for block in section.blocks -%}
        {%- if block.type == 'platform' and block.settings.url != blank -%}
          <a href="{{ block.settings.url }}" class="platform-row" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
            <div class="platform-logo">{{ block.settings.logo }}</div>
            <span class="platform-name-inline">{{ block.settings.name }}</span>
            <span class="platform-handle">{{ block.settings.handle }}</span>
            <span class="platform-blurb">{{ block.settings.blurb }}</span>
            <span class="platform-arrow">→</span>
          </a>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</section>

<!-- LIGHTBOX -->
<div class="lightbox-overlay" id="lightbox" onclick="closeLightboxOnBg(event)">
  <div class="lightbox-inner" id="lightbox-inner">
    <button class="lightbox-close" onclick="closeLightbox()">✕</button>
    <div class="lightbox-video" id="lightbox-video"></div>
  </div>
</div>

<script>
  function openLightbox(videoId, orientation) {
    var inner = document.getElementById('lightbox-inner');
    var video = document.getElementById('lightbox-video');
    inner.className = 'lightbox-inner' + (orientation === 'landscape' ? ' landscape' : '');
    video.innerHTML = '<iframe src="https://www.youtube.com/embed/' + videoId + '?autoplay=1&rel=0" allowfullscreen allow="autoplay"></iframe>';
    document.getElementById('lightbox').classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    document.getElementById('lightbox').classList.remove('active');
    document.getElementById('lightbox-video').innerHTML = '';
    document.body.style.overflow = '';
  }
  function closeLightboxOnBg(e) {
    if (e.target === document.getElementById('lightbox')) closeLightbox();
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

