              </div>
              <div class="rc-body">
                {%- if time_tag != blank -%}<div class="rc-tag">{{ time_tag }}</div>{%- endif -%}
                <div class="rc-name">{{ found.title }}</div>
                {%- if found.excerpt != blank -%}<div class="rc-meta">{{ found.excerpt | strip_html | truncate: 80 }}</div>{%- endif -%}
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

    </div>
  </div>
</section>
{%- endif -%}


{%- comment -%}════════════════════════════════════════════════════════
  9. DISCOVER
  Extends es-discover.liquid — same metafield logic, homepage uses blocks.

  Homepage:    article picker blocks (up to 4)
  Other pages: auto-detected metafield by context —
    product    → custom.product_related_articles
                 (fallback: custom.bundle_related_articles)
    collection → custom.discover_articles
    article    → custom.recipe_related_articles
                 (fallback: custom.blog_related_articles)

  Per card:
    NATIVE    — article.title, article.image, article.url, article.excerpt
    METAFIELD — custom.blog_read_time
    NATIVE    — article.tags mapped to category labels:
                  ingredient-knowledge · food-system-insights ·
                  traditional-food-practices · health-nutrition
════════════════════════════════════════════════════════{%- endcomment -%}

{%- liquid
  assign discover_raw = nil
  if product != blank
    assign discover_raw = product.metafields.custom.product_related_articles.value
    if discover_raw == blank
      assign discover_raw = product.metafields.custom.bundle_related_articles.value
    endif
  elsif collection != blank
    assign discover_raw = collection.metafields.custom.discover_articles.value
  elsif article != blank
    assign discover_raw = article.metafields.custom.recipe_related_articles.value
    if discover_raw == blank
      assign discover_raw = article.metafields.custom.blog_related_articles.value
    endif
  endif
  assign discover_handles = discover_raw | split: ';'
-%}

{%- assign discover_blocks = section.blocks | where: 'type', 'discover_article' -%}
{%- assign show_discover = false -%}
{%- if discover_raw != blank or discover_blocks.size > 0 -%}{%- assign show_discover = true -%}{%- endif -%}

{%- if show_discover -%}
<section class="discover-section">
  <div class="discover-inner">
    <div class="section-hd">
      <h2 class="block-title">{{ section.settings.discover_title | default: 'From Our Blog' }}</h2>
      {%- if section.settings.discover_show_all -%}
        <a href="/blogs/{{ blog_handle_discover }}">{{ section.settings.discover_all_label | default: 'All Articles →' }}</a>
      {%- endif -%}
    </div>
    <div class="article-grid">

      {%- if discover_raw == blank and discover_blocks.size > 0 -%}
        {%- comment -%} Homepage: article picker blocks {%- endcomment -%}
        {%- assign count = 0 -%}
        {%- for block in discover_blocks -%}
          {%- if count >= 4 -%}{%- break -%}{%- endif -%}
          {%- assign found = block.settings.article -%}
          {%- if found != blank -%}
            {%- assign count = count | plus: 1 -%}
            {%- assign read_time = found.metafields.custom.blog_read_time.value -%}
            {%- assign cat_label = nil -%}
            {%- for tag in found.tags -%}
              {%- if discover_category_tags contains tag -%}
                {%- assign cat_label = tag | replace: '-', ' ' | capitalize -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if cat_label == nil and found.tags.size > 0 -%}
              {%- assign cat_label = found.tags.first | replace: '-', ' ' | capitalize -%}
            {%- endif -%}
            <a href="{{ found.url }}" class="article-card" {{ block.shopify_attributes }}>
              <div class="ac-img">
                {%- if found.image -%}{{ found.image | image_url: width: 500 | image_tag: loading: 'lazy', widths: '250, 375, 500', sizes: '(min-width: 990px) 25vw, 50vw', style: 'object-fit:cover;width:100%;height:100%;', width: 500, height: 330 }}{%- endif -%}
                {%- if read_time != blank -%}<div class="ac-read-time">{{ read_time }}</div>{%- endif -%}
              </div>
              <div class="ac-body">
                {%- if cat_label != blank -%}<div class="ac-cat">{{ cat_label }}</div>{%- endif -%}
                <div class="ac-title">{{ found.title }}</div>
                {%- if found.excerpt != blank -%}<div class="ac-excerpt">{{ found.excerpt | strip_html | truncate: 100 }}</div>{%- endif -%}
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}

      {%- elsif discover_raw != blank -%}
        {%- comment -%} Product / Collection / Article: metafield handles {%- endcomment -%}
        {%- assign count = 0 -%}
        {%- for handle_raw in discover_handles -%}
          {%- if count >= 3 -%}{%- break -%}{%- endif -%}
          {%- assign a_handle = handle_raw | strip -%}
          {%- assign article_path = blog_handle_discover | append: '/' | append: a_handle -%}
          {%- assign found = articles[article_path] -%}
          {%- if found != blank -%}
            {%- assign count = count | plus: 1 -%}
            {%- assign read_time = found.metafields.custom.blog_read_time.value -%}
            {%- assign cat_label = nil -%}
            {%- for tag in found.tags -%}
              {%- if discover_category_tags contains tag -%}
                {%- assign cat_label = tag | replace: '-', ' ' | capitalize -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if cat_label == nil and found.tags.size > 0 -%}
              {%- assign cat_label = found.tags.first | replace: '-', ' ' | capitalize -%}
            {%- endif -%}
            <a href="{{ found.url }}" class="article-card">
              <div class="ac-img">
                {%- if found.image -%}{{ found.image | image_url: width: 500 | image_tag: loading: 'lazy', widths: '250, 375, 500', sizes: '(min-width: 990px) 25vw, 50vw', style: 'object-fit:cover;width:100%;height:100%;', width: 500, height: 330 }}{%- endif -%}
                {%- if read_time != blank -%}<div class="ac-read-time">{{ read_time }}</div>{%- endif -%}
              </div>
              <div class="ac-body">
                {%- if cat_label != blank -%}<div class="ac-cat">{{ cat_label }}</div>{%- endif -%}
                <div class="ac-title">{{ found.title }}</div>
                {%- if read_time != blank -%}<div class="ac-excerpt">{{ read_time }}</div>
                {%- elsif found.excerpt != blank -%}<div class="ac-excerpt">{{ found.excerpt | strip_html | truncate: 60 }}</div>
                {%- endif -%}
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

    </div>
  </div>
</section>
{%- endif -%}


{%- comment -%}════════════════════════════════════════════════════════
  10. EMAIL SIGNUP
  DEV — all content via section settings.
  Klaviyo embed if klaviyo_form_id is set, else native Shopify form.
════════════════════════════════════════════════════════{%- endcomment -%}

<section class="email-section">
  <div class="email-block">
    <div>
      <span class="email-eyebrow">{{ section.settings.email_eyebrow | default: 'Our Community' }}</span>
      <h2>{{ section.settings.email_heading | default: 'Recipes, Food Knowledge & Updates — In Your Inbox' }}</h2>
      <p>{{ section.settings.email_body | default: 'Seasonal recipes, ingredient guides, and traditional food knowledge. Once a week. No spam, ever.' }}</p>
    </div>
    <div class="email-right">
      {%- if section.settings.klaviyo_form_id != blank -%}
        <div class="klaviyo-form-{{ section.settings.klaviyo_form_id }}"></div>
      {%- else -%}
        {%- form 'customer', id: 'homepage-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="email-form">
            <label class="email-form-label" for="newsletter-email">{{ section.settings.email_form_label | default: 'Your email address' }}</label>
            <input class="email-input" type="email" name="contact[email]" id="newsletter-email" placeholder="you@example.com" autocomplete="email" required>
            <button type="submit" class="email-btn">{{ section.settings.email_btn_label | default: 'Join the Community →' }}</button>
            <p class="email-fine">{{ section.settings.email_fine_print | default: 'No spam. Unsubscribe anytime.' }}</p>
          </div>
        {%- endform -%}
      {%- endif -%}
    </div>
  </div>
</section>


