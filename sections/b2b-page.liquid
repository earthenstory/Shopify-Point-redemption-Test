    },
    {
      "type": "text",
      "id": "supply_subtitle",
      "label": "Subtitle",
      "default": "Browse any category to see individual products, certifications, and specifications."
    },
    {
      "type": "text",
      "id": "supply_browse_text",
      "label": "Browse link prefix text",
      "default": "Full product range at"
    },
