      "type": "header",
      "content": "— Why Source From Us —"
    },
    {
      "type": "text",
      "id": "trust_eyebrow",
      "label": "Eyebrow text",
      "default": "Why Earthen Story"
    },
    {
      "type": "text",
      "id": "trust_title",
      "label": "Section heading",
      "default": "What Sets Our Supply Apart"
    },
    {
      "type": "header",
