    {
      "type": "text",
      "id": "hero_title_em",
      "label": "Headline — italic second line",
      "default": "for Businesses.",
      "info": "Displayed in italics on the second line of the hero heading"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Sub-headline paragraph",
      "default": "Consistent supply of genuinely organic, lab-tested products — backed by transaction certificates, NABL lab reports, and FSSAI certification. For distributors, HoReCa, and export buyers who need traceability they can rely on."
    },
    {
      "type": "text",
      "id": "hero_cta_primary_label",
      "label": "Primary CTA label",
      "default": "Send an Inquiry"
    },
    {
      "type": "text",
      "id": "hero_cta_ghost_label",
      "label": "Ghost CTA label",
      "default": "View Lab Reports →"
    },
    {
      "type": "text",
      "id": "hero_audience_label",
      "label": "Audience column heading",
      "default": "We supply to"
    },
    {
      "type": "header",
      "content": "— Mission —"
    },
    {
      "type": "text",
      "id": "mission_eyebrow",
      "label": "Eyebrow text",
      "default": "Why We Started"
    },
    {
