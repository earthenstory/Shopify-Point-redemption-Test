generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CustomerStatus {
  active
  disabled
  anonymized
}

enum LedgerEntryType {
  migration_credit
  order_earn
  signup_bonus
  redeem_reserve
  redeem_consume
  redeem_release
  refund_reversal
  order_cancel_reversal
  expiry
  manual_adjustment
}

enum RedemptionStatus {
  pending
  applied
  consumed
  partially_consumed
  released
  expired
  failed
  manual_review
}

enum WebhookEventStatus {
  received
  processed
  failed
  ignored
}

enum DiscountCleanupStatus {
  pending
  complete
  failed
}

enum LoyaltyProgramStatus {
  test
  active
  paused
}

enum MilestoneType {
  signup
  first_order
  order_count
  spend_amount
  birthday
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model LoyaltyCustomer {
  id                String              @id @default(cuid())
  shopDomain        String
  shopifyCustomerId String
  email             String?
  phone             String?
  firstName         String?
  lastName          String?
  status            CustomerStatus      @default(active)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  wallet            Wallet?
  ledgerEntries     LedgerEntry[]
  pointLots         PointLot[]
  redemptions       RedemptionSession[]
  adminAuditLogs    AdminAuditLog[]

  @@unique([shopDomain, shopifyCustomerId])
  @@index([shopDomain, email])
  @@index([shopDomain, phone])
}

model Wallet {
  id                     String          @id @default(cuid())
  customerId             String          @unique
  customer               LoyaltyCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  availablePoints        Int             @default(0)
  pendingPoints          Int             @default(0)
  lifetimeEarnedPoints   Int             @default(0)
  lifetimeRedeemedPoints Int             @default(0)
  lifetimeExpiredPoints  Int             @default(0)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  ledgerEntries          LedgerEntry[]
}

model LedgerEntry {
  id                  String             @id @default(cuid())
  customerId          String
  customer            LoyaltyCustomer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  walletId            String
  wallet              Wallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type                LedgerEntryType
  pointsDelta         Int
  moneyValue          Decimal?           @db.Decimal(12, 2)
  currency            String             @default("INR")
  shopifyOrderId      String?
  shopifyRefundId     String?
  redemptionSessionId String?
  redemptionSession   RedemptionSession? @relation(fields: [redemptionSessionId], references: [id])
  description         String?
  metadata            Json?
  createdAt           DateTime           @default(now())

  @@index([customerId, createdAt])
  @@index([shopifyOrderId])
  @@index([redemptionSessionId])
}

model PointLot {
  id                  String          @id @default(cuid())
  customerId          String
  customer            LoyaltyCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sourceLedgerEntryId String
  originalPoints      Int
  remainingPoints     Int
  expiresAt           DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([customerId, expiresAt])
}

model RedemptionSession {
  id                    String                @id @default(cuid())
  customerId            String
  customer              LoyaltyCustomer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  cartToken             String?
  checkoutToken         String?
  shopifyOrderId        String?
  pointsReserved        Int
  pointsConsumed        Int                   @default(0)
  pointsReleased        Int                   @default(0)
  discountAmount        Decimal               @db.Decimal(12, 2)
  actualDiscountAmount  Decimal?              @db.Decimal(12, 2)
  currency              String                @default("INR")
  discountCode          String                @unique
  shopifyDiscountNodeId String?
  rewardType            RewardType?
  rewardTitle           String?
  status                RedemptionStatus      @default(pending)
  expiresAt             DateTime
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  ledgerEntries         LedgerEntry[]
  cleanupJobs           DiscountCleanupJob[]

  @@index([customerId, status])
  @@index([cartToken])
  @@index([shopifyOrderId])
}

model RewardRule {
  id                          String   @id @default(cuid())
  shopDomain                  String
  earningEnabled              Boolean  @default(true)
  redemptionEnabled           Boolean  @default(true)
  earnRatePercent             Decimal  @db.Decimal(5, 2)
  pointsPerCurrencyUnit       Decimal  @db.Decimal(10, 4)
  pointsPerSpendAmount        Decimal  @default(2) @db.Decimal(10, 2)
  spendAmountForEarnPoints    Decimal  @default(100) @db.Decimal(10, 2)
  currencyValuePerPoint       Decimal  @db.Decimal(10, 4)
  signupRewardPoints          Int      @default(250)
  minRedeemPoints             Int      @default(10)
  redeemIncrementPoints       Int      @default(10)
  maxRedeemPointsPerOrder     Int?
  maxRedeemPercentOfCart      Decimal  @db.Decimal(5, 2)
  allowDiscountStacking       Boolean  @default(false)
  discountCodeTtlMinutes      Int      @default(60)
  awardOnStatus               String   @default("fulfilled")
  pointsExpiryDays            Int?
  returnRedeemedPointsOnRefund Boolean @default(true)
  reverseEarnedPointsOnRefund Boolean @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([shopDomain])
}

model LoyaltyProgramSettings {
  id                    String               @id @default(cuid())
  shopDomain            String               @unique
  status                LoyaltyProgramStatus @default(test)
  programName           String               @default("Earthen Loyalty")
  pointName             String               @default("Earthen Points")
  testModeCustomerTag   String?
  launchChecklist       Json?
  bonWidgetDisabled     Boolean              @default(false)
  standardCheckoutTested Boolean             @default(false)
  expressCheckoutTested Boolean              @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
}

model LoyaltyWidgetSettings {
  id                    String   @id @default(cuid())
  shopDomain            String   @unique
  homepageEnabled       Boolean  @default(true)
  productEnabled        Boolean  @default(true)
  cartEnabled           Boolean  @default(true)
  accountEnabled        Boolean  @default(true)
  loggedOutMessage      String   @default("Sign in to see your Earthen Points and unlock cart rewards.")
  zeroPointsMessage     String   @default("You do not have Earthen Points yet. Create an account or place an order to start earning.")
  primaryColor          String   @default("#112557")
  accentColor           String   @default("#cca268")
  backgroundColor       String   @default("#fffaf0")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum RewardType {
  fixed_amount
  percent_off
  free_shipping
}

enum ReferralStatus {
  pending
  rewarded
  blocked
}

// Fixed-cost rewards a customer can claim with points (BON parity: multiple
// reward types beyond the slider's amount-off-order redemption).
model RewardDefinition {
  id          String     @id @default(cuid())
  shopDomain  String
  title       String
  type        RewardType
  pointsCost  Int
  value       Decimal?   @db.Decimal(12, 2)
  minSubtotal Decimal?   @db.Decimal(12, 2)
  enabled     Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([shopDomain, enabled])
}

// "Ways to earn" beyond orders: social follows / custom links a customer can
// claim points for (once per customer by default — fraud guard).
model EarnAction {
  id              String            @id @default(cuid())
  shopDomain      String
  title           String
  url             String?
  points          Int
  enabled         Boolean           @default(true)
  oncePerCustomer Boolean           @default(true)
  sortOrder       Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  claims          EarnActionClaim[]

  @@index([shopDomain, enabled])
}

model EarnActionClaim {
  id         String     @id @default(cuid())
  actionId   String
  action     EarnAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  customerId String
  createdAt  DateTime   @default(now())

  @@unique([actionId, customerId])
  @@index([customerId])
}

model ReferralProgramSettings {
  id               String   @id @default(cuid())
  shopDomain       String   @unique
  enabled          Boolean  @default(false)
  referrerPoints   Int      @default(200)
  refereePoints    Int      @default(100)
  minOrderSubtotal Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ReferralCode {
  id         String   @id @default(cuid())
  customerId String   @unique
  code       String   @unique
  createdAt  DateTime @default(now())
}

// One attribution per referee (fraud guard); rewarded only after the referee's
// first qualifying paid/fulfilled order.
model ReferralAttribution {
  id                 String         @id @default(cuid())
  shopDomain         String
  code               String
  referrerCustomerId String
  refereeCustomerId  String         @unique
  status             ReferralStatus @default(pending)
  shopifyOrderId     String?
  blockedReason      String?
  createdAt          DateTime       @default(now())
  rewardedAt         DateTime?

  @@index([referrerCustomerId])
  @@index([shopDomain, status])
}

// VIP tiers derive from lifetime earned points; membership is computed on the
// fly (highest enabled tier at or below the wallet's lifetimeEarnedPoints), so
// there is no assignment state to drift.
model VipTier {
  id              String   @id @default(cuid())
  shopDomain      String
  name            String
  thresholdPoints Int
  earnMultiplier  Decimal  @default(1) @db.Decimal(5, 2)
  enabled         Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shopDomain, enabled, thresholdPoints])
}

// Limited-time point offer: multiplies order earn while active.
model PointsCampaign {
  id         String   @id @default(cuid())
  shopDomain String
  title      String
  multiplier Decimal  @default(2) @db.Decimal(5, 2)
  startsAt   DateTime
  endsAt     DateTime
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shopDomain, enabled, startsAt, endsAt])
}

model LoyaltyMilestoneRule {
  id                    String        @id @default(cuid())
  shopDomain            String
  type                  MilestoneType
  title                 String
  enabled               Boolean       @default(false)
  points                Int
  thresholdAmount       Decimal?      @db.Decimal(12, 2)
  thresholdOrderCount   Int?
  repeatable            Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([shopDomain, type])
}

model BonMigrationBatch {
  id                 String              @id @default(cuid())
  shopDomain         String
  sourceFileName     String?
  rawExportUri       String?
  sourceRowCount     Int
  validRowCount      Int
  invalidRowCount    Int
  totalSourcePoints  Int
  totalImportedPoints Int
  status             WebhookEventStatus  @default(received)
  createdBy          String
  createdAt          DateTime            @default(now())
  importedAt         DateTime?
  rows               BonMigrationRow[]
}

model BonMigrationRow {
  id                 String            @id @default(cuid())
  batchId            String
  batch              BonMigrationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rowIndex           Int
  shopifyCustomerId  String?
  email              String?
  phone              String?
  points             Int?
  matchedCustomerId  String?
  ledgerEntryId      String?
  error              String?
  raw                Json
  createdAt          DateTime          @default(now())

  @@index([batchId, rowIndex])
  @@index([email])
  @@index([phone])
}

model WebhookEvent {
  id               String             @id @default(cuid())
  shopifyWebhookId String             @unique
  topic            String
  shopDomain       String
  resourceId       String?
  payloadHash      String
  status           WebhookEventStatus @default(received)
  attemptCount     Int                @default(0)
  lastError        String?
  createdAt        DateTime           @default(now())
  processedAt      DateTime?

  @@index([topic, resourceId])
}

model AdminAuditLog {
  id         String           @id @default(cuid())
  adminUser  String
  action     String
  customerId String?
  customer   LoyaltyCustomer? @relation(fields: [customerId], references: [id])
  before     Json?
  after      Json?
  reason     String
  createdAt  DateTime         @default(now())
}

model DiscountCleanupJob {
  id                    String                @id @default(cuid())
  redemptionSessionId   String
  redemptionSession     RedemptionSession     @relation(fields: [redemptionSessionId], references: [id], onDelete: Cascade)
  shopifyDiscountNodeId String?
  discountCode          String
  status                DiscountCleanupStatus @default(pending)
  attemptCount          Int                   @default(0)
  lastError             String?
  nextAttemptAt         DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([status, nextAttemptAt])
}

model DeliverySettings {
  shopDomain       String   @id
  enabled          Boolean  @default(false)
  pickupPincode    String   @default("560048")
  cutoffHour       Int      @default(11)
  // ISO weekday numbers that count as working days (1=Mon ... 7=Sun).
  workingDays      String   @default("1,2,3,4,5,6")
  // Array of "YYYY-MM-DD" strings — extra non-working dates.
  holidays         Json     @default("[]")
  defaultWeightKg  Decimal  @default(0.5) @db.Decimal(6, 2)
  // "recommended" = Shiprocket's pick; "fastest" = lowest transit days.
  courierStrategy  String   @default("recommended")
  surfaceOnly      Boolean  @default(true)
  // When no surface courier serves the pincode, fall back to any courier
  // instead of telling the customer we cannot deliver.
  fallbackToAny    Boolean  @default(true)
  showRange        Boolean  @default(false)
  widgetTitle      String   @default("Check delivery date")
  cacheTtlMinutes  Int      @default(720)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ShiprocketToken {
  id        String    @id @default("default")
  token     String?   @db.Text
  expiresAt DateTime?
  updatedAt DateTime  @updatedAt
}

model DeliveryEstimateCache {
  id           String   @id @default(cuid())
  pincode      String
  weightBucket Int
  cod          Boolean  @default(false)
  serviceable  Boolean
  courierName  String?
  transitDays  Int?
  isSurface    Boolean?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@unique([pincode, weightBucket, cod])
  @@index([expiresAt])
}
