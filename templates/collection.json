y-item a {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  text-decoration: none;\n  color: #222;\n}\n\n.image-container {\n  background: #F4F2E9;\n  border-radius: 50%;\n  padding: 12px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.category-item img {\n  width: 56px;\n  height: 56px;\n  object-fit: contain;\n}\n\n.category-item span {\n  margin-top: 6px;\n  font-size: 13px;\n  font-weight: 500;\n  white-space: nowrap;\n}\n\n\/* Tablet & Desktop *\/\n@media (min-width: 768px) {\n  .categories-container {\n    justify-content: center;\n    overflow-x: visible;\n    gap: 32px;\n  }\n\n  .category-item img {\n    width: 66px;\n    height: 66px;\n  }\n\n  .category-item span {\n    font-size: 16px;\n  }\n}\n<\/style>",
