            "custom_liquid_wNLEib": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<link rel=\"stylesheet\" href=\"https:\/\/fonts.googleapis.com\/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,220,1,0\" \/>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .benefits-container {\n            display: flex;\n            flex-wrap: wrap;\n            justify-content: space-between;\n            padding: 20px;\n            background-color: #ffffff;\n            border-radius: 10px;\n            max-width: 600px;\n            margin: 0 auto;\n        }\n        .benefit {\n            display: flex;\n            align-items: center;\n            width: 45%;\n            margin: 10px 0;\n            font-size: 13px;\n        }\n        .benefit-icon {\n            font-size: 22px;\n            margin-right: 10px;\n        }\n    <\/style>\n\n\n<div class=\"benefits-container\">\n    <div class=\"benefit\">\n        <span class=\"material-symbols-outlined benefit-icon\">new_releases<\/span>\n        <div>100% Pure<\/div>\n    <\/div>\n    <div class=\"benefit\">\n        <span class=\"material-symbols-outlined benefit-icon\">new_releases<\/span>\n        <div>No Bleaching<\/div>\n    <\/div>\n    <div class=\"benefit\">\n        <span class=\"material-symbols-outlined benefit-icon\">new_releases<\/span>\n        <div>No Adulteration<\/div>\n    <\/div>\n    <div class=\"benefit\">\n        <span class=\"material-symbols-outlined benefit-icon\">new_releases<\/span>\n        <div>No Preservatives<\/div>\n    <\/div>\n<\/div>"
              },
              "blocks": {}
            },
            "custom_liquid_PLV4MA": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<!-- reviews-carousel.liquid -->\n<div class=\"review-carousel\">\n    <div class=\"reviews-wrapper\">\n        <!-- Carousel Items -->\n        <div class=\"review-item\">\n            <div class=\"review-badge\">⭐⭐⭐⭐⭐<\/div>\n            <p>\"Quality seeds at great prices! Earthen Story is my go-to place for chia and basil seeds. The packaging and service are excellent!\"<\/p>\n            <h4>- Sarah M.<\/h4>\n        <\/div>\n        \n        <div class=\"review-item\">\n            <div class=\"review-badge\">⭐⭐⭐⭐⭐<\/div>\n            <p>\"Fresh and reliable! Their chia and basil seeds are consistently of high quality, and delivery is always prompt.\"<\/p>\n            <h4>- John D.<\/h4>\n        <\/div>\n\n        <div class=\"review-item\">\n            <div class=\"review-badge\">⭐⭐⭐⭐⭐<\/div>\n            <p>\"Best place for organic seeds! The products are fresh, and I love supporting their eco-friendly packaging initiatives.\"<\/p>\n            <h4>- Emily P.<\/h4>\n        <\/div>\n    <\/div>\n\n    <!-- Navigation Buttons (Optional) -->\n    <button class=\"prev\" onclick=\"prevSlide()\">&#10094;<\/button>\n    <button class=\"next\" onclick=\"nextSlide()\">&#10095;<\/button>\n<\/div>\n\n<!-- Styles -->\n<style>\n.review-carousel {\n    position: relative;\n    max-width: 800px;\n    margin: auto;\n    overflow: hidden;\n}\n\n.reviews-wrapper {\n    display: flex;\n    transition: transform 0.5s ease-in-out;\n}\n\n.review-item {\n    min-width: 100%;\n    box-sizing: border-box;\n    padding: 20px;\n    text-align: center;\n}\n\n.review-badge {\n    font-size: 1.5em;\n    color: #ffcc00;\n    margin-bottom: 10px;\n}\n\n.prev, .next {\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    font-size: 18px;\n    padding: 10px;\n    cursor: pointer;\n    background-color: #000;\n    color: #fff;\n    border: none;\n    opacity: 0.5;\n    transition: 0.3s;\n}\n\n.prev:hover, .next:hover {\n    opacity: 1;\n}\n\n.prev {\n    left: 0;\n}\n\n.next {\n    right: 0;\n}\n<\/style>\n\n<!-- Script -->\n<script>\nlet currentSlide = 0;\nlet autoplayInterval;\n\n\/\/ Show a specific slide\nfunction showSlide(slideIndex) {\n    const slides = document.querySelector('.reviews-wrapper');\n    const totalSlides = document.querySelectorAll('.review-item').length;\n    \n    \/\/ Handle overflow when reaching the end\/start of slides\n    if (slideIndex >= totalSlides) currentSlide = 0;\n    if (slideIndex < 0) currentSlide = totalSlides - 1;\n    \n    \/\/ Move the carousel\n    slides.style.transform = 'translateX(' + (-currentSlide * 100) + '%)';\n}\n\n\/\/ Go to the next slide\nfunction nextSlide() {\n    currentSlide++;\n    showSlide(currentSlide);\n}\n\n\/\/ Go to the previous slide\nfunction prevSlide() {\n    currentSlide--;\n    showSlide(currentSlide);\n}\n\n\/\/ Autoplay functionality\nfunction startAutoplay() {\n    autoplayInterval = setInterval(function() {\n        nextSlide();\n    }, 3000); \/\/ Change every 3 seconds\n}\n\n\/\/ Stop autoplay on user interaction (optional)\nfunction stopAutoplay() {\n    clearInterval(autoplayInterval);\n}\n\n\/\/ Initialize the carousel and start autoplay on page load\ndocument.addEventListener('DOMContentLoaded', function() {\n    showSlide(currentSlide);\n    startAutoplay();\n\n    \/\/ Optional: If you want autoplay to stop when user clicks the buttons\n    document.querySelector('.prev').addEventListener('click', stopAutoplay);\n    document.querySelector('.next').addEventListener('click', stopAutoplay);\n});\n<\/script>"
              },
              "blocks": {}
            }
