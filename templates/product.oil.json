            "custom_liquid_NUXV6e": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<div id=\"kopstorm-snippet-9\">\n\n  <style>\n    \/* USP wrapper *\/\n    #kopstorm-snippet-9 .usp-list {\n      display: flex;\n      flex-direction: column;\n      gap: 6px;\n      margin: 0;\n      padding: 0;\n    }\n\n    \/* each USP line *\/\n    #kopstorm-snippet-9 .usp-item {\n      display: flex;\n      align-items: center;\n      font-size: 14px;\n      line-height: 1.45;\n      color: #000;\n    }\n\n    \/* icon styling *\/\n    #kopstorm-snippet-9 .usp-item svg {\n      width: 18px;\n      height: 18px;\n      margin-right: 8px;\n      flex-shrink: 0;\n      fill: #000000; \/* black icons *\/\n    }\n  <\/style>\n\n  <div class=\"usp-list\">\n\n    <!-- Certified Organic -->\n    <div class=\"usp-item\">\n      <svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" viewBox=\"0 0 512 512\">\n        <!-- check \/ organic -->\n        <path d=\"M173.898 439.404l-166.4-166.4c-12.497-12.497-12.497-32.758 0-45.255s32.758-12.497 45.255 0L192 372.093 459.147 104.944c12.497-12.497 32.758-12.497 45.255 0s12.497 32.758 0 45.255L218.727 439.404c-12.497 12.497-32.758 12.497-45.255 0z\"\/>\n      <\/svg>\n      <span>Certified Organic<\/span>\n    <\/div>\n\n    <!-- Traditionally Cold Pressed -->\n    <div class=\"usp-item\">\n      <svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" viewBox=\"0 0 576 512\">\n        <!-- traditional press icon -->\n        <path d=\"M288 0C132.9 0 0 35.8 0 80s132.9 80 288 80s288-35.8 288-80S443.1 0 288 0zm0 192C132.9 192 0 227.8 0 272s132.9 80 288 80s288-35.8 288-80s-132.9-80-288-80z\"\/>\n      <\/svg>\n      <span>Traditionally Cold Pressed<\/span>\n    <\/div>\n\n    <!-- Free Shipping -->\n    <div class=\"usp-item\">\n      <svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" viewBox=\"0 0 640 512\">\n        <!-- truck icon -->\n        <path d=\"M48 0C21.5 0 0 21.5 0 48V368c0 26.5 21.5 48 48 48H64c0 53 43 96 96 96s96-43 96-96H384c0 53 43 96 96 96s96-43 96-96h32c17.7 0 32-14.3 32-32s-14.3-32-32-32V288z\"\/>\n  