    "custom_liquid_Nc64h7": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "{% if blog.all_tags.size > 0 %}\n  <div class=\"blog-tag-filter\">\n    <a href=\"{{ blog.url }}\">All<\/a>\n    {% for tag in blog.all_tags %}\n      <a href=\"{{ blog.url }}\/tagged\/{{ tag | handle }}\">\n        {{ tag }}\n      <\/a>\n    {% endfor %}\n  <\/div>\n{% endif %}\n\n<style>\n.blog-tag-filter {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  margin-bottom: 25px;\n}\n\n.blog-tag-filter a {\n  padding: 6px 14px;\n  border: 1px solid #ccc;\n  border-radius: 20px;\n  font-size: 14px;\n  text-decoration: none;\n  color: #000;\n}\n\n.blog-tag-filter a:hover {\n  background: #000;\n  color: #fff;\n}\n<\/style>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
