{%- liquid
  assign context = context | default: 'inline'
  assign section_id = section.id | default: ''
  assign subtotal = cart.items_subtotal_price | divided_by: 100.0

  assign loyalty_applied_amount = 0
  assign loyalty_applied_code = ''
  for discount in cart.cart_level_discount_applications
    assign discount_prefix = discount.title | slice: 0, 8
    if discount_prefix == 'ESPOINTS'
      assign loyalty_applied_amount = discount.total_allocated_amount | divided_by: 100.0
      assign loyalty_applied_code = discount.title
    endif
  endfor
-%}

<earthen-loyalty-widget
  class="earthen-loyalty earthen-loyalty--{{ context }}"
  data-context="{{ context }}"
  data-section-id="{{ section_id }}"
  data-cart-token="{{ cart.token }}"
  data-cart-subtotal="{{ subtotal }}"
  data-applied-amount="{{ loyalty_applied_amount }}"
  data-applied-code="{{ loyalty_applied_code }}"
  {%- comment -%}
    Keep the JS-populated inner DOM across cart-section morphs. Without this, a
    cart update re-applies this empty server skeleton (blanking the balance and
    slider) and the widget has to re-fetch + re-render, which reads as a flicker.
    Root attributes (hidden, data-cart-subtotal, data-applied-*) still update from
    the server; only the children are preserved. The JS re-asserts `hidden`
    visibility synchronously after each morph.
  {%- endcomment -%}
  data-skip-subtree-update
  hidden
>
  <div class="earthen-loyalty__inner">
    <div class="earthen-loyalty__header">
      <span class="earthen-loyalty__label">Earthen Points</span>
      <span class="earthen-loyalty__value" data-loyalty-value></span>
    </div>
    <p class="earthen-loyalty__message" data-loyalty-message></p>
    <div class="earthen-loyalty__redeem" data-loyalty-redeem hidden>
      <div class="earthen-loyalty__applied-summary" data-loyalty-applied hidden>
        <span data-loyalty-applied-text></span>
        <button
          class="earthen-loyalty__remove-icon"
          type="button"
          data-loyalty-remove
          aria-label="Remove Earthen Points discount"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="earthen-loyalty__range-row" data-loyalty-range-row>
        <input
          class="earthen-loyalty__range"
          type="range"
          min="0"
          step="10"
          value="0"
          data-loyalty-range
          aria-label="Points to redeem"
        >
        <span class="earthen-loyalty__selected" data-loyalty-selected></span>
      </div>
      <div class="earthen-loyalty__actions">
        <button class="earthen-loyalty__button" type="button" data-loyalty-apply>
          Apply points
        </button>
      </div>
    </div>
    <div class="earthen-loyalty__history" data-loyalty-history hidden></div>
  </div>
</earthen-loyalty-widget>
